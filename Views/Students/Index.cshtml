@model IEnumerable<Student_portal.Web.Models.Entities.Student>

@{
    ViewData["Title"] = "Students";
}

<section class="hero-panel mb-4">
    <div>
        <p class="eyebrow">Student Portal</p>
        <h1>Manage your students in one place</h1>
        <p class="hero-copy">Track contact details, monitor active subscriptions, and keep your student records updated.</p>
    </div>
    <a class="btn btn-primary btn-lg" asp-action="Create">Add Student</a>
</section>

@if (TempData["StatusMessage"] is string statusMessage)
{
    <div class="alert alert-success shadow-sm" role="alert">
        @statusMessage
    </div>
}

<section class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Subscription</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Any())
                {
                    @foreach (var student in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@student.Name</td>
                            <td>@student.Email</td>
                            <td>@student.Phone</td>
                            <td>
                                @if (student.Subscription)
                                {
                                    <span class="badge rounded-pill text-bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge rounded-pill text-bg-secondary">Inactive</span>
                                }
                            </td>
                            <td class="text-end">
                                <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@student.Id">Details</a>
                                <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@student.Id">Edit</a>
                                <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@student.Id">Delete</a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center py-5">
                            <h2 class="h5 mb-2">No students yet</h2>
                            <p class="text-muted mb-3">Create your first student record to get started.</p>
                            <a class="btn btn-primary" asp-action="Create">Create Student</a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</section>
